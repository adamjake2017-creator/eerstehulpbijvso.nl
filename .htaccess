# ============================================================================
#  Eerste hulp bij VSO - redirects & canonicalisatie
#  Doel: (1) www -> non-www zodat Google's rankingsignalen niet splitsen,
#        (2) oude WordPress-URL's (nu 404) omzetten naar de juiste nieuwe
#            pagina's met een 301, zodat resterende linkwaarde behouden blijft
#            en de oude pagina's uit de Google-index verdwijnen.
# ============================================================================

<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- Canonical: www -> non-www (301) --------------------------------------
  RewriteCond %{HTTP_HOST} ^www\.eerstehulpbijvso\.nl$ [NC]
  RewriteRule ^(.*)$ https://eerstehulpbijvso.nl/$1 [R=301,L]

  # --- Oude WordPress-pagina's -> best passende nieuwe pagina (301) ---------
  RewriteRule ^vaststellingsovereenkomst-vso/?$ /wat-is-een-vaststellingsovereenkomst.html [R=301,L]
  RewriteRule ^belangrijke-punten-bij-vaststellingsovereenkomst/?$ /wat-is-een-vaststellingsovereenkomst.html [R=301,L]
  RewriteRule ^gratis-pdf-eerste-hulp-bij-vso/?$ /10-valkuilen-bij-een-vso.html [R=301,L]
  RewriteRule ^5-veelgemaakte-fouten-bij-een-vaststellingsovereenkomst/?$ /10-valkuilen-bij-een-vso.html [R=301,L]
  RewriteRule ^moet-ik-mijn-vaststellingsovereenkomst-tekenen-7-vragen-die-je-eerst-moet-beantwoorden/?$ /vaststellingsovereenkomst/is-mijn-vso-een-goede-deal.html [R=301,L]

  # --- Oude portfolio-items -> passende nieuwe pagina (301) -----------------
  RewriteRule ^portfolio/vaststellingsovereenkomst-vso-bij-ziekte/?$ /vaststellingsovereenkomst/tijdens-ziekte.html [R=301,L]
  RewriteRule ^portfolio/wat-zijn-de-voordelen-van-een-vaststellingsovereenkomst-vso/?$ /voor-en-nadelen-vaststellingsovereenkomst.html [R=301,L]
  RewriteRule ^portfolio/wat-staat-er-in-een-vaststellingsovereenkomst-vso/?$ /wat-is-een-vaststellingsovereenkomst.html [R=301,L]
  # Alle overige portfolio-URL's gaan naar de kernuitleg
  RewriteRule ^portfolio(/.*)?$ /wat-is-een-vaststellingsovereenkomst.html [R=301,L]

  # --- Oude thema-demopagina's (Attorna/Divi) -> homepage (301) ------------
  RewriteRule ^personnel(/.*)?$ / [R=301,L]
  RewriteRule ^price-table/?$ / [R=301,L]

</IfModule>
